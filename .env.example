# Tríade Ω · variables locales
# Copiar como .env o exportar manualmente en terminal.

# API key local para proteger endpoints sensibles.
# Si está vacía/no definida, la API opera en modo abierto local.
TRIADE_API_KEY=cambia-esta-clave-local

# Orígenes CORS permitidos, separados por coma.
# n8n local por defecto usa http://localhost:5678 o http://127.0.0.1:5678
TRIADE_CORS_ORIGINS=http://127.0.0.1:5678,http://localhost:5678

# ── Continuous Runner (modo 24/7) ──────────────────────────────────
# DESACTIVADO por defecto. Activar solo con conciencia del costo.
# TRIADE_CONTINUOUS_RUNNER=0          # "1" para activar (default: 0)
# TRIADE_CONTINUOUS_INTERVAL_SECONDS=10  # Sleep entre ciclos (min: 10)
# TRIADE_CONTINUOUS_MAX_CYCLES=0      # 0 = ilimitado; N = máximo N ciclos
# TRIADE_AUTONOMY_LEVEL=observe_only  # observe_only|form_candidates|train_candidates|promote_experimental|promote_stable

# ── Life Pulse ──────────────────────────────────────────────────────
# TRIADE_LIFE_PULSE_INTERVAL=60       # Segundos entre ticks de observación
# TRIADE_LIFE_REFLECTION_LIMIT=30     # Máximo de items en self-reflection
