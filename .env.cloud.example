# Copiar como .env.cloud en el VPS. Nunca confirmar .env.cloud en Git.
TRIADE_DOMAIN=triade.example.com
TRIADE_API_KEY=replace-with-a-long-random-secret
POSTGRES_PASSWORD=replace-with-a-long-random-secret

# Runtime existente
PYTHONUNBUFFERED=1
TRIADE_ALWAYS_ON_ENABLED=1

# Ollama puede vivir en otro nodo privado. Dejar vacío conserva el modo degradado.
OLLAMA_HOST=

# Futuras integraciones cloud. Actualmente se exponen al contenedor para la migración gradual.
DATABASE_URL=postgresql://triade:replace-with-a-long-random-secret@postgres:5432/triade
REDIS_URL=redis://valkey:6379/0
